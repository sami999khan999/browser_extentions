{
  "manifest_version": 3,
  "name": "YouTube Time Tracker",
  "version": "1.0.1",
  "description": "Take control of your YouTube experience. Track watch time, analyze viewing habits, and stay focused with an integrated Shorts blocker and intelligent break reminders.",
  "icons": {
    "16": "icons/icon128.jpg",
    "48": "icons/icon128.jpg",
    "128": "icons/icon128.jpg"
  },
  "permissions": ["storage", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://zenquotes.io/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": [
        "src/shared/theme.css",
        "src/shared/modal.css",
        "src/stats-tracker/toggle-button.css",
        "src/stats-tracker/sidebar.css",
        "src/stats-tracker/dashboard.css",
        "src/stats-tracker/charts.css",
        "src/settings/settings.css",
        "src/break-reminder/break-modal.css",
        "src/init/responsive.css"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "YouTube Time Tracker",
    "default_icon": {
      "16": "icons/icon128.jpg",
      "32": "icons/icon128.jpg",
      "48": "icons/icon128.jpg",
      "128": "icons/icon128.jpg"
    }
  }
}
